{
  "manifest_version": 3,
  "name": "Link Booster",
  "version": "2.2",
  "description": "Boost your links! Clean tracking params, auto-detect language for social sharing, shorten URLs, and generate QR codes.",
  "permissions": [
    "contextMenus",
    "scripting",
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://tinyurl.com/*",
    "https://werjvrzdbpbyasftmlkl.supabase.co/*",
    "<all_urls>"
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Copy Decoded Link",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/social-share-logos/*.svg",
        "assets/icons/*.png",
        "options.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js",
        "assets/jsQR.js",
        "qr_detector.js"
      ],
      "css": [
        "qr_styles.css"
      ]
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://link-booster.link/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  }
}